# Self-Soul-B多模态AGI系统环境变量配置示例
# 复制此文件为.env并填入真实的API密钥

# ====================
# OpenAI配置
# ====================
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1  # 可选: 自定义端点或代理
OPENAI_MODEL=gpt-4o  # 可选: gpt-4-turbo, gpt-3.5-turbo
OPENAI_ORGANIZATION=org-your-org-id  # 可选: 组织ID
OPENAI_PROJECT=proj-your-project-id  # 可选: 项目ID

# ====================
# Anthropic配置
# ====================
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-opus-20240229  # 可选: claude-3-sonnet, claude-3-haiku
ANTHROPIC_VERSION=2023-06-01

# ====================
# Google AI配置
# ====================
# 获取地址: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-pro  # 可选: gemini-ultra, gemini-nano
GOOGLE_SAFETY_SETTINGS=moderate  # 可选: block_none, block_some, block_most, block_all

# ====================
# AWS Bedrock配置
# ====================
# 需要AWS账户和Bedrock访问权限
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1  # 可选: us-west-2, eu-central-1, etc.
AWS_BEDROCK_MODEL=anthropic.claude-3-sonnet-20240229-v1:0

# ====================
# Azure OpenAI配置
# ====================
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_MODEL=gpt-4

# ====================
# 国内API提供商配置
# ====================

# 智谱AI (Zhipu)
# 获取地址: https://open.bigmodel.cn/
ZHIPUAI_API_KEY=your-zhipuai-api-key-here
ZHIPUAI_MODEL=glm-4  # 可选: glm-3-turbo, charglm-3

# 百度文心 (ERNIE)
# 获取地址: https://console.bce.baidu.com/qianfan/
BAIDU_API_KEY=your-baidu-api-key
BAIDU_SECRET_KEY=your-baidu-secret-key
BAIDU_MODEL=ernie-bot-4.0  # 可选: ernie-bot-turbo, ernie-bot

# 阿里通义千问
# 获取地址: https://dashscope.aliyun.com/
ALIBABA_API_KEY=your-alibaba-api-key
ALIBABA_MODEL=qwen-plus  # 可选: qwen-turbo, qwen-max

# 讯飞星火
# 获取地址: https://www.xfyun.cn/
XUNFEI_APP_ID=your-xunfei-app-id
XUNFEI_API_KEY=your-xunfei-api-key
XUNFEI_API_SECRET=your-xunfei-api-secret
XUNFEI_MODEL=v3.0  # 可选: v2.0, v1.5

# 腾讯混元
# 获取地址: https://cloud.tencent.com/product/hunyuan
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
TENCENT_MODEL=hunyuan-standard  # 可选: hunyuan-lite

# ====================
# 开源/自托管配置
# ====================

# HuggingFace推理端点
# 获取地址: https://huggingface.co/inference-endpoints
HF_API_KEY=your-huggingface-api-key
HF_ENDPOINT_URL=https://your-endpoint.huggingface.cloud
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.1

# Ollama本地模型
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2  # 可选: mistral, codellama, phi

# vLLM本地推理
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=meta-llama/Llama-2-7b-chat-hf

# ====================
# 通用API配置
# ====================

# 连接设置
API_TIMEOUT=60  # 请求超时时间（秒）
API_MAX_RETRIES=3  # 最大重试次数
API_RETRY_DELAY=1  # 重试延迟（秒）

# 性能设置
API_MAX_CONNECTIONS=10  # 最大并发连接数
API_ENABLE_CACHE=true  # 启用响应缓存
API_CACHE_TTL=3600  # 缓存存活时间（秒）

# 安全设置
API_ENABLE_RATE_LIMITING=true  # 启用速率限制
API_REQUESTS_PER_MINUTE=60  # 每分钟最大请求数
API_TOKENS_PER_MINUTE=100000  # 每分钟最大令牌数

# 模型参数
API_DEFAULT_TEMPERATURE=0.7  # 默认温度参数
API_DEFAULT_MAX_TOKENS=4096  # 默认最大令牌数
API_DEFAULT_TOP_P=0.9  # 默认top_p参数

# ====================
# 系统配置
# ====================

# 日志级别
LOG_LEVEL=INFO  # 可选: DEBUG, INFO, WARNING, ERROR
LOG_TO_FILE=true  # 是否记录到文件
LOG_FILE_PATH=./logs/system.log  # 日志文件路径

# 调试模式
DEBUG_MODE=false  # 启用调试模式
API_TEST_MODE=false  # API测试模式（不发送真实请求）

# 数据目录
DATA_DIR=./data  # 数据存储目录
MODEL_CACHE_DIR=./model_cache  # 模型缓存目录

# ====================
# 多模态处理配置
# ====================

# 图像处理
IMAGE_MAX_SIZE_MB=10  # 最大图像大小（MB）
IMAGE_SUPPORTED_FORMATS=jpg,png,gif,webp  # 支持的图像格式

# 音频处理
AUDIO_MAX_SIZE_MB=50  # 最大音频大小（MB）
AUDIO_SUPPORTED_FORMATS=mp3,wav,flac,ogg  # 支持的音频格式

# 视频处理
VIDEO_MAX_SIZE_MB=100  # 最大视频大小（MB）
VIDEO_MAX_DURATION_SECONDS=300  # 最大视频时长（秒）
VIDEO_SUPPORTED_FORMATS=mp4,avi,mov,webm  # 支持的视频格式

# ====================
# 机器人硬件配置
# ====================

# ROS配置
ROS_MASTER_URI=http://localhost:11311
ROS_IP=127.0.0.1

# 串口配置
SERIAL_PORT=/dev/ttyUSB0  # Linux
# SERIAL_PORT=COM3  # Windows
SERIAL_BAUDRATE=115200

# 网络配置
ROBOT_IP=192.168.1.100
ROBOT_PORT=9090

# ====================
# 注意事項
# ====================

# 1. 永远不要提交真实的API密钥到版本控制
# 2. 将此文件添加到.gitignore
# 3. 使用环境变量管理敏感信息
# 4. 定期轮换API密钥