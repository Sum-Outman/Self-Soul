    def coordinate_task(self, task_description: str, *args, **kwargs) -> Dict[str, Any]:
        """Coordinate multiple models to complete tasks
        
        兼容父类签名 (required_resources: Dict[str, Any]) 和子类签名 (required_models: List[str], priority: int)
        """
        try:
            self.logger.info(f"Starting task coordination: {task_description}")
            
            # 解析参数：兼容父类和子类签名
            required_models = None
            priority = 5
            
            # 检查kwargs中的参数
            if 'required_models' in kwargs:
                required_models = kwargs['required_models']
            elif 'required_resources' in kwargs:
                # 父类签名：从required_resources中提取模型列表
                required_resources = kwargs['required_resources']
                if isinstance(required_resources, dict) and 'models' in required_resources:
                    required_models = required_resources['models']
            
            # 检查args中的参数
            if args:
                if len(args) >= 1 and isinstance(args[0], list):
                    required_models = args[0]
                if len(args) >= 2 and isinstance(args[1], int):
                    priority = args[1]
            
            # 如果还没有获取到required_models，尝试从kwargs的其他位置获取
            if required_models is None and 'models' in kwargs:
                required_models = kwargs['models']
            
            # 确定所需模型
            if not required_models:
                required_models = self._determine_required_models(task_description)
            
            # 检查所有所需模型的可用性
            unavailable_models = [model for model in required_models if model not in self.sub_models or self.sub_models[model] is None]
            if unavailable_models:
                return {
                    "status": "failed",
                    "message": f"Unavailable models: {unavailable_models}",
                    "unavailable_models": unavailable_models
                }
            
            # 创建协调任务ID
            task_id = f"coord_{int(time.time())}_{zlib.adler32(task_description.encode('utf-8')) & 0xffffffff}"
            
            # 启动模型协调
            coordination_result = self._initiate_model_coordination(task_description, task_id, required_models)
            coordination_result["task_description"] = task_description
            
            # 监控协调过程
